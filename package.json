{
  "name": "incowgnito",
  "version": "1.0.0",
  "description": "Private mail alias relay compatible with the addy.io API, powered by mailcow",
  "main": "src/index.ts",
  "scripts": {
    "scss:build": "sass src/scss:public/assets/default/css --style=compressed --no-source-map",
    "scss:watch": "sass src/scss:public/assets/default/css --watch",
    "build": "npm run scss:build",
    "prestart": "npm run scss:build",
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx --watch src/index.ts & npm run scss:watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "mysql2": "^3.11.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
